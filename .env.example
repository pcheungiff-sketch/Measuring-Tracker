# Copy to .env.local for local development

# Vercel Postgres (auto-populated when you add Vercel Postgres to your project)
POSTGRES_URL=
POSTGRES_PRISMA_URL=
POSTGRES_URL_NO_SSL=
POSTGRES_URL_NON_POOLING=
POSTGRES_USER=
POSTGRES_HOST=
POSTGRES_PASSWORD=
POSTGRES_DATABASE=

# Auth
JWT_SECRET=your-secret-key-change-this-to-something-random-and-long

# Email (get from resend.com - free tier works)
RESEND_API_KEY=re_xxxxxxxxxxxx

# App URL (no trailing slash)
NEXT_PUBLIC_BASE_URL=https://yourdomain.vercel.app

# Cron security (generate a random string)
CRON_SECRET=your-cron-secret-here
